{
  "name": "bidforge",
  "private": true,
  "packageManager": "npm@11.5.2",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "npm run dev --workspace=web",
    "dev:api": "cd api && uv sync && uv run uvicorn app.main:app --reload --port 8000",
    "build": "turbo run build --filter=web",
    "lint": "npm run lint --workspace=web",
    "test:api": "cd api && uv sync && uv run pytest tests/ -v"
  },
  "devDependencies": {
    "turbo": "^2.5.4"
  }
}
