# Runtime
ENV=development
LOG_LEVEL=info

# Clerk — issuer = Frontend API URL; secret required in production (not used for JWT verify)
CLERK_ISSUER=https://YOUR_INSTANCE.clerk.accounts.dev
CLERK_SECRET_KEY=
# Optional: set SKIP_AUTH=1 for local development without JWT verification
SKIP_AUTH=0

# LLM (OpenRouter — required for POST /api/proposal/run unless injecting StubLLM in tests)
OPENROUTER_API_KEY=
OPENROUTER_MODEL_PRIMARY=anthropic/claude-3.5-sonnet
OPENROUTER_MODEL_FALLBACK=openai/gpt-4o-mini
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small
OPENROUTER_HTTP_REFERER=https://bidforge.app

# Langfuse (server only — never expose keys to Next.js)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_TRACING_ENVIRONMENT=development

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Legacy: RAG user resolution uses `public.users.id` with `clerk_user_id` only (this key is unused by retrieval).
SUPABASE_USERS_PK_COLUMN=id

# Limits (optional)
PIPELINE_TIMEOUT_S=120
PER_AGENT_TIMEOUT_S=30
RFP_MAX_CHARS=120000
RATE_LIMIT_PER_MINUTE=30

# Comma-separated extra CORS origins for the web app (e.g. https://*.vercel.app)
CORS_ALLOW_ORIGINS=